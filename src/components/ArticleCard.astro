---
import { topicToSlug } from '../lib/topics'

interface Props {
  title: string
  slug: string
  summary: string
  topic: string
  date: string
  author: string
}

const { title, slug, summary, topic, date, author } = Astro.props

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})
---

<article class="group py-7 border-b border-neutral-100 dark:border-neutral-800/60 last:border-b-0">
  <div class="flex items-center gap-1.5 text-xs text-neutral-400 dark:text-neutral-500">
    <a
      href={`/topic/${topicToSlug(topic)}/`}
      class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-200"
    >
      {topic}
    </a>
    <span>&middot;</span>
    <time datetime={date}>{formattedDate}</time>
    <span>&middot;</span>
    <span>{author}</span>
  </div>
  <a href={`/article/${slug}/`} class="block mt-2">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors duration-200">
      {title}
    </h2>
  </a>
  <p class="mt-2.5 text-neutral-500 dark:text-neutral-400 leading-relaxed line-clamp-2">
    {summary}
  </p>
</article>
