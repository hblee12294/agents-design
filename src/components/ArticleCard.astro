---
import { topicToSlug } from '../lib/topics'

interface Props {
  title: string
  slug: string
  summary: string
  topic: string
  date: string
  author: string
}

const { title, slug, summary, topic, date, author } = Astro.props

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
})
---

<article class="group py-7 border-b border-stone-200/60 dark:border-stone-700/40 last:border-b-0">
  <div class="flex items-center gap-1.5 text-xs text-stone-400 dark:text-stone-500">
    <a
      href={`/topic/${topicToSlug(topic)}/`}
      class="text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200"
    >
      {topic}
    </a>
    <span>&middot;</span>
    <time datetime={date}>{formattedDate}</time>
    <span>&middot;</span>
    <span>{author}</span>
  </div>
  <a href={`/article/${slug}/`} class="block mt-2">
    <h2 class="text-2xl font-bold text-stone-800 dark:text-stone-200 group-hover:text-stone-600 dark:group-hover:text-stone-300 transition-colors duration-200">
      {title}
    </h2>
  </a>
  <p class="mt-2.5 lg:text-lg text-stone-500 dark:text-stone-400 leading-relaxed line-clamp-2">
    {summary}
  </p>
</article>
