---
import ThemeToggle from './ThemeToggle.astro'
---

<header class="border-b border-neutral-100 dark:border-neutral-800/60">
  <div class="mx-auto max-w-6xl flex items-center justify-between px-8 lg:px-12 py-6">
    <a href="/" class="flex items-center gap-2.5">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-7 w-7 shrink-0">
        <rect width="32" height="32" rx="7" fill="#111" class="dark:fill-neutral-200" />
        <g stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none" class="dark:[stroke:#111]">
          <path d="M6 24V12L10 8L14 12V24M6 18H14" />
          <path d="M18 8V24H20C24 24 26 20 26 16S24 8 20 8H18" />
        </g>
      </svg>
      <span class="text-base font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
        Agents Design
      </span>
    </a>
    <ThemeToggle />
  </div>
</header>
