---
import { getCollection } from "astro:content";
import { getOrderedTopics, topicToSlug } from "../lib/topics";

interface Props {
  activeTopic: string | null;
}

const { activeTopic } = Astro.props;
const allArticles = await getCollection("articles");
const topics = getOrderedTopics(allArticles.map((a) => a.data.topic));
---

<nav class="space-y-0.5">
  <h3
    class="mb-4 text-xs font-semibold uppercase tracking-wider text-stone-400 dark:text-stone-500"
  >
    Topics
  </h3>
  {
    topics.map((topic) => (
      <a
        href={`/topic/${topicToSlug(topic)}/`}
        class:list={[
          "block py-1.5 text-[0.9rem] transition-colors",
          activeTopic === topic
            ? "text-stone-800 font-semibold dark:text-stone-200"
            : "text-stone-400 hover:text-stone-800 dark:text-stone-500 dark:hover:text-stone-200",
        ]}
      >
        {topic}
      </a>
    ))
  }
</nav>
