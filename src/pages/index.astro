---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import ArticleCard from '../components/ArticleCard.astro'
import { getOrderedTopics } from '../lib/topics'

const allArticles = await getCollection('articles')
const topics = getOrderedTopics(allArticles.map((a) => a.data.topic))
const defaultTopic = topics[0]
const articles = allArticles
  .filter((a) => a.data.topic === defaultTopic)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<BaseLayout
  title="Agents Design — AI Agent Design Patterns & Best Practices"
  description="A curated collection of the best articles on AI agent design patterns, best practices, and architecture."
  activeTopic={defaultTopic}
>
  <section>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.data.slug}
        summary={article.data.summary}
        topic={article.data.topic}
        date={article.data.date}
        author={article.data.author}
      />
    ))}
  </section>
</BaseLayout>
