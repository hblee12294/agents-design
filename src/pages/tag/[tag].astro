---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { tagToSlug } from '../../lib/topics'

export async function getStaticPaths() {
  const allArticles = await getCollection('articles')
  const tagMap = new Map<string, string>()
  for (const article of allArticles) {
    for (const tag of article.data.tags) {
      tagMap.set(tagToSlug(tag), tag)
    }
  }
  return Array.from(tagMap.entries()).map(([slug, tag]) => ({
    params: { tag: slug },
    props: { tagName: tag },
  }))
}

interface Props {
  tagName: string
}

const { tagName } = Astro.props
const allArticles = await getCollection('articles')
const articles = allArticles
  .filter((a) => a.data.tags.includes(tagName))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<BaseLayout
  title={`Tag: ${tagName} — Agents Design`}
  description={`Articles tagged "${tagName}".`}
  activeTopic={null}
>
  <div class="mb-8 flex items-center gap-2 text-sm text-stone-400 dark:text-stone-500">
    <a href="/" class="hover:text-stone-800 dark:hover:text-stone-200 transition-colors">
      All articles
    </a>
    <span>/</span>
    <span class="text-stone-800 dark:text-stone-200 font-medium">
      Tag: {tagName}
    </span>
  </div>
  <section>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.data.slug}
        summary={article.data.summary}
        topic={article.data.topic}
        date={article.data.date}
        author={article.data.author}
      />
    ))}
  </section>
</BaseLayout>
