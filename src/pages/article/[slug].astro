---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { topicToSlug, tagToSlug } from '../../lib/topics'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
const { title, summary, topic, date, author, tags, originalUrl } = article.data

const allArticles = await getCollection('articles')
const tagCounts = new Map<string, number>()
for (const a of allArticles) {
  for (const tag of a.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => a.tag.localeCompare(b.tag))

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
})
---

<BaseLayout
  title={`${title} — Agents Design`}
  description={summary}
  activeTopic={topic}
>
  <article>
    <a
      href={`/topic/${topicToSlug(topic)}/`}
      class="group/back inline-flex items-center gap-1.5 text-sm text-stone-400 dark:text-stone-500 hover:text-stone-800 dark:hover:text-stone-200 transition-colors mb-10"
    >
      <svg class="h-4 w-4 transition-transform duration-200 group-hover/back:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      {topic}
    </a>

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-stone-800 dark:text-stone-200 leading-tight">
        {title}
      </h1>
      <p class="mt-4 text-lg lg:text-xl text-stone-500 dark:text-stone-400 leading-relaxed">
        {summary}
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-2">
        {tags.map((tag) => (
          <a
            href={`/tag/${tagToSlug(tag)}/`}
            class="inline-flex items-center rounded-full border border-stone-200 dark:border-stone-700 px-2.5 py-0.5 text-xs text-stone-500 dark:text-stone-400 hover:border-stone-400 dark:hover:border-stone-500 hover:text-stone-700 dark:hover:text-stone-200 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
      <div class="mt-6 flex items-center gap-1.5 text-sm text-stone-400 dark:text-stone-500">
        <span>{author}</span>
        <span>&middot;</span>
        <time datetime={date}>{formattedDate}</time>
      </div>
    </header>

    <div class="prose lg:prose-lg prose-stone dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-accent-600 dark:prose-a:text-accent-400 prose-a:underline-offset-2">
      <Content />
    </div>

    <div class="mt-10">
      <a
        href={originalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-stone-800 dark:bg-stone-100 px-5 py-2.5 text-sm font-medium text-white dark:text-stone-800 no-underline hover:bg-stone-700 dark:hover:bg-stone-200 transition-colors duration-200"
      >
        Read the original
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>

    <section class="mt-20 pt-10 border-t border-stone-200/60 dark:border-stone-700/40">
      <h2 class="text-lg font-bold text-stone-800 dark:text-stone-200 mb-5">
        Discover more
      </h2>
      <div class="flex flex-wrap gap-2">
        {sortedTags.map(({ tag, count }) => (
          <a
            href={`/tag/${tagToSlug(tag)}/`}
            class="inline-flex items-center gap-1.5 rounded-full border border-stone-200 dark:border-stone-700 px-3 py-1 text-sm text-stone-600 dark:text-stone-300 hover:border-stone-400 dark:hover:border-stone-500 hover:text-stone-800 dark:hover:text-stone-200 transition-colors"
          >
            {tag}
            <span class="text-stone-400 dark:text-stone-500 text-xs">{count}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
