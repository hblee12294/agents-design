---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { topicToSlug, tagToSlug } from '../../lib/topics'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
const { title, summary, topic, date, author, tags } = article.data

const allArticles = await getCollection('articles')
const tagCounts = new Map<string, number>()
for (const a of allArticles) {
  for (const tag of a.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
  }
}
const sortedTags = Array.from(tagCounts.entries())
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => a.tag.localeCompare(b.tag))

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={`${title} — Agents Design`}
  description={summary}
  activeTopic={topic}
>
  <article>
    <a
      href={`/topic/${topicToSlug(topic)}/`}
      class="group/back inline-flex items-center gap-1.5 text-sm text-neutral-400 dark:text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors mb-10"
    >
      <svg class="h-4 w-4 transition-transform duration-200 group-hover/back:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      {topic}
    </a>

    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 leading-tight">
        {title}
      </h1>
      <p class="mt-4 text-lg text-neutral-500 dark:text-neutral-400 leading-relaxed">
        {summary}
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-2">
        {tags.map((tag) => (
          <a
            href={`/tag/${tagToSlug(tag)}/`}
            class="inline-flex items-center rounded-full border border-neutral-200 dark:border-neutral-700 px-2.5 py-0.5 text-xs text-neutral-500 dark:text-neutral-400 hover:border-neutral-400 dark:hover:border-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-200 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
      <div class="mt-6 flex items-center gap-1.5 text-sm text-neutral-400 dark:text-neutral-500">
        <span>{author}</span>
        <span>&middot;</span>
        <time datetime={date}>{formattedDate}</time>
      </div>
    </header>

    <div class="prose prose-neutral dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-accent-600 dark:prose-a:text-accent-400 prose-a:underline-offset-2">
      <Content />
    </div>

    <section class="mt-20 pt-10 border-t border-neutral-100 dark:border-neutral-800/60">
      <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-5">
        Discover more
      </h2>
      <div class="flex flex-wrap gap-2">
        {sortedTags.map(({ tag, count }) => (
          <a
            href={`/tag/${tagToSlug(tag)}/`}
            class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 dark:border-neutral-700 px-3 py-1 text-sm text-neutral-600 dark:text-neutral-300 hover:border-neutral-400 dark:hover:border-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
          >
            {tag}
            <span class="text-neutral-400 dark:text-neutral-500 text-xs">{count}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
